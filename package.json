{
  "name": "sigql-workspace",
  "version": "0.0.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build:lib": "ng build sigql",
    "build:demo": "ng build demo",
    "build": "pnpm run build:lib && pnpm run build:demo",
    "watch:lib": "ng build sigql --watch",
    "server": "node demo/server/index.js",
    "dev": "concurrently \"pnpm run server\" \"pnpm run start\"",
    "test": "ng test sigql",
    "lint": "prettier --check .",
    "prepare": "husky",
    "release": "commit-and-tag-version"
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/router": "^22.0.5",
    "graphql": "^16.13.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "commit-and-tag-version": "^13.0.0",
    "concurrently": "^9.2.1",
    "graphql-ws": "^5.16.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "ng-packagr": "^22.0.1",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "commit-and-tag-version": {
    "bumpFiles": [
      "package.json",
      "sigql/package.json"
    ]
  }
}
